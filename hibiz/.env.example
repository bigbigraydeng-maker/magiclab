# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# OpenAI — server only (generation). Never expose to client.
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Jina Reader Pro — enables JS rendering wait for TradeMe gallery images
# Get key: https://jina.ai/reader → Sign up → API Keys
# JINA_API_KEY=jina_...

# Optional for Edge Functions / server-only (do not expose to browser)
# SUPABASE_SERVICE_ROLE_KEY=

# One-off schema apply via Management API (scripts/apply-schema-api.mjs) — never commit real values
# Create token: https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=sbp_...
# SUPABASE_PROJECT_REF=your_project_ref_id
